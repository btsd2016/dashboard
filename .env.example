# ============================================================
# TSD Group Dashboard — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to version control
# For production, use Railway environment variables instead

# ============================================================
# Deputy API (Labour & Schedules)
# ============================================================
DEPUTY_SUBDOMAIN=827eb203093602.au.deputy.com
DEPUTY_TOKEN=YOUR_10_YEAR_DEPUTY_BEARER_TOKEN

# ============================================================
# Square API (POS Sales)
# ============================================================
SQUARE_APP_ID=sq0idp-YOUR_APP_ID
SQUARE_ACCESS_TOKEN=YOUR_SQUARE_ACCESS_TOKEN

# ============================================================
# Xero API (Accounting)
# ============================================================
XERO_CLIENT_ID=YOUR_XERO_CLIENT_ID
XERO_CLIENT_SECRET=YOUR_XERO_CLIENT_SECRET
XERO_REDIRECT_URI=https://localhost:3000/auth/xero/callback

# ============================================================
# Google OAuth (Dashboard Login)
# ============================================================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://localhost:3000/auth/google/callback

# ============================================================
# Session & Security
# ============================================================
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-random-session-secret-here

# ============================================================
# AI Insights (Claude API) — Optional
# ============================================================
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development
